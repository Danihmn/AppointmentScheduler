name: dockercompose5143631444156370117
services:
  appointment-scheduler:
    build:
      context: C:\dev_dotnet\ASP.NET\AppointmentScheduler\AppointmentScheduler
      dockerfile: AppointmentScheduler/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: AppointmentScheduler
      target: base
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      ConnectionStrings__DefaultConnection: Server=host.docker.internal,1433;Database=AppointmentSchedulerDB;User Id=sa;Password=Admin1234;TrustServerCertificate=True;
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
    image: danihmn/appointment-scheduler:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net10.0/AppointmentScheduler.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      appointment-scheduler_network: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
      - mode: ingress
        target: 8443
        published: "8443"
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\danie\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\danie\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\danie\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\Users\danie\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind: {}
      - type: bind
        source: C:\dev_dotnet\ASP.NET\AppointmentScheduler\AppointmentScheduler\AppointmentScheduler
        target: /app
        bind: {}
      - type: bind
        source: C:\dev_dotnet\ASP.NET\AppointmentScheduler\AppointmentScheduler
        target: /src
        bind: {}
      - type: bind
        source: C:\Users\danie\vsdbg\vs2017u5
        target: /remote_debugger
        bind: {}
      - type: bind
        source: C:\Users\danie\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net6.0
        target: /VSTools
        read_only: true
        bind: {}
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Community\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind: {}
networks:
  appointment-scheduler_network:
    name: dockercompose5143631444156370117_appointment-scheduler_network
    driver: bridge